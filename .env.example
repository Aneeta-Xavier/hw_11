# Copy to .env and fill in. The app reads these from the environment.

# Required for the real agent (CONCIERGE_MODE=agent). Programmatic SDK use is
# billed via the Anthropic API.
ANTHROPIC_API_KEY=sk-ant-...

# Absolute path of the repository the concierge answers questions about.
# Defaults to the current working directory if unset.
CONCIERGE_TARGET_REPO=/absolute/path/to/some/repo

# Hard cap on agent-loop turns per request (default 25).
CONCIERGE_MAX_TURNS=25

# "agent" (default) = real Claude Agent SDK loop.
# "echo"           = trivial echo stub, for verifying the web plumbing with no API key.
CONCIERGE_MODE=agent

# Optional shared password. When set, visitors must enter it before they can
# chat (protects a public deployment from spending your API credits). Leave
# blank/unset for an open app.
CONCIERGE_PASSWORD=
